@{
    ViewData["Title"] = "Tebessümünü Paylaş";
    int todayCount = ViewBag.TodayCount ?? 0;
    int totalCount = ViewBag.TotalCount ?? 0;
}
@section Head {
    <title>@ViewData["Title"] — Tebessüm Sadakadır</title>
}

<!-- ════════════════════════════════ AUTH MODAL ═══════════════════════════════ -->
<div class="auth-modal-overlay hidden" id="authModal">
  <div class="auth-modal-card">
    <div class="auth-modal-header">
      <h2 class="auth-modal-title">Tebessümünü Kime Yazalım?</h2>
      <p class="auth-modal-subtitle">Puanların sana gelsin diye, küçük bir not bırak.</p>
    </div>
    <div class="auth-tabs">
      <button class="auth-tab active" data-tab="register" id="tabRegister">Kayıt Ol</button>
      <button class="auth-tab" data-tab="login" id="tabLogin">Giriş Yap</button>
    </div>
    <form class="auth-form active" id="formRegister">
      <div class="auth-form-group">
        <label for="regDisplayName">İsim / Kullanıcı Adı</label>
        <input type="text" id="regDisplayName" name="displayName" required autocomplete="username" />
      </div>
      <div class="auth-form-group">
        <label for="regPin">4 Haneli PIN</label>
        <input type="text" id="regPin" name="pin" pattern="[0-9]{4}" maxlength="4" required autocomplete="off" placeholder="0000" />
      </div>
      <button type="submit" class="auth-submit-btn">Kayıt Ol</button>
      <div class="auth-status" id="registerStatus"></div>
    </form>
    <form class="auth-form hidden" id="formLogin">
      <div class="auth-form-group">
        <label for="loginDisplayName">İsim / Kullanıcı Adı</label>
        <input type="text" id="loginDisplayName" name="displayName" required autocomplete="username" />
      </div>
      <div class="auth-form-group">
        <label for="loginPin">4 Haneli PIN</label>
        <input type="text" id="loginPin" name="pin" pattern="[0-9]{4}" maxlength="4" required autocomplete="off" placeholder="0000" />
      </div>
      <button type="submit" class="auth-submit-btn">Giriş Yap</button>
      <div class="auth-status" id="loginStatus"></div>
    </form>
  </div>
</div>

<!-- ════════════════════════════════ GÜNLÜK LİMİT MODAL ══════════════════════ -->
<div class="modal-backdrop hidden" id="limitModal" role="dialog" aria-modal="true">
  <div class="modal-card limit-modal-card">
    <div class="modal-icon-wrap">
      <div class="modal-icon">🌙</div>
      <div class="modal-icon-ring" aria-hidden="true"></div>
    </div>
    <h2 class="modal-title" style="font-size:22px;">Bugünlük Tebessümler Tamam!</h2>
    <p class="modal-body" style="font-size:15px; line-height:1.7;">
      İbadetin az ama sürekli yapılanı makbuldür,<br>
      yarın tekrar bekleriz 👋😄
    </p>
    <div class="limit-streak-info" id="limitStreakInfo" style="display:none;">
      <span class="limit-streak-badge" id="limitStreakBadge">🔥 3 Günlük Seri!</span>
    </div>
    <button class="btn btn-primary btn-wide" onclick="closeLimitModal()" style="margin-top:8px;">
      Tamam, Yarın Görüşürüz ✨
    </button>
  </div>
</div>

<!-- ════════════════════════════════ BEKLEME MODAL ═══════════════════════════ -->
<div class="modal-backdrop hidden" id="waitModal" role="dialog" aria-modal="true">
  <div class="modal-card" style="text-align:center;">
    <div class="modal-icon-wrap">
      <div class="modal-icon">⏳</div>
      <div class="modal-icon-ring" aria-hidden="true"></div>
    </div>
    <h2 class="modal-title" style="font-size:22px;">Biraz Daha Bekle</h2>
    <p class="modal-body" style="font-size:14px; line-height:1.7; margin-bottom:16px;">
      Yüklemeler arasında en az <strong>1 saat</strong> geçmelidir.<br>
      Bir sonraki tebessümün için kalan süre:
    </p>

    <!-- Geri sayım -->
    <div class="wait-countdown" id="waitCountdown">
      <div class="wait-time-box">
        <span class="wait-time-num" id="waitHours">00</span>
        <span class="wait-time-label">saat</span>
      </div>
      <span class="wait-time-sep">:</span>
      <div class="wait-time-box">
        <span class="wait-time-num" id="waitMinutes">00</span>
        <span class="wait-time-label">dakika</span>
      </div>
      <span class="wait-time-sep">:</span>
      <div class="wait-time-box">
        <span class="wait-time-num" id="waitSeconds">00</span>
        <span class="wait-time-label">saniye</span>
      </div>
    </div>

    <p style="font-size:12px; color:var(--petrol-200); margin:12px 0 20px; opacity:.7;">
      Sabır da bir ibadettir 🌿
    </p>
    <button class="btn btn-primary btn-wide" onclick="closeWaitModal()">
      Tamam, Bekleyeceğim
    </button>
  </div>
</div>

<!-- ════════════════════════════════ HERO HEADER ═══════════════════════════════ -->
<header class="site-header">
  <div class="header-bg-lines" aria-hidden="true">
    <span></span><span></span><span></span><span></span>
  </div>
  <div class="header-inner">
    <div class="header-left">
      <div class="header-eyebrow">
        <span class="eyebrow-dot"></span>
        İyilik Kılavuzu ~ Ahlaki Duruş
        <span class="eyebrow-dot"></span>
      </div>
      <h1 class="site-title">
        Tebessüm Etmek<br />
        <em>Sadakadır</em>
      </h1>
      <p class="site-subtitle">Bir fotoğraf çek, bir sadaka bırak.</p>
    </div>
    <div class="header-right">
      <blockquote class="hero-hadith">
        <p>Kardeşinin yüzüne tebessüm etmen bile sana sadaka olarak yazılır.</p>
        <cite>— Tirmizî, Birr 36</cite>
      </blockquote>
    </div>
  </div>

  <!-- STAT BAR -->
  <div class="stat-bar">
    <div class="stat-bar-inner">
      <div class="stat-item">
        <div class="stat-top">
          <span class="stat-icon">📷</span>
          <span class="stat-num" id="statToday" data-target="@todayCount">@todayCount</span>
        </div>
        <span class="stat-label">BUGÜN YÜKLENEN TEBESSÜM</span>
      </div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div class="stat-item">
        <div class="stat-top">
          <span class="stat-icon">😊</span>
          <span class="stat-num" id="statTotal" data-target="@totalCount">@totalCount</span>
        </div>
        <span class="stat-label">TOPLAM TEBESSÜM</span>
      </div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div class="stat-item" id="statPointsItem">
        <div class="stat-top">
          <span class="stat-icon">⭐</span>
          <span class="stat-num" id="statPoints">—</span>
        </div>
        <span class="stat-label">SADAKA PUANIM</span>
      </div>
    </div>
  </div>
</header>

<!-- ════════════════════════════════ MAIN CONTENT ══════════════════════════════ -->
<main class="site-main">
  <div class="main-grid">

    <section class="camera-col" aria-label="Kamera">
      <div class="col-eyebrow">
        <span class="eyebrow-line"></span>
        Tebessümünü Paylaş
        <span class="eyebrow-line"></span>
      </div>

      <div class="camera-frame" id="cameraFrame">
        <video id="videoEl" autoplay muted playsinline></video>
        <canvas id="canvasEl" aria-hidden="true"></canvas>
        <div class="camera-placeholder" id="cameraPlaceholder">
          <div class="placeholder-inner">
            <div class="placeholder-ring">
              <div class="placeholder-icon">📷</div>
            </div>
            <p>Kamera bekleniyor…</p>
          </div>
        </div>
        <span class="corner-guide tl"></span>
        <span class="corner-guide tr"></span>
        <span class="corner-guide bl"></span>
        <span class="corner-guide br"></span>
        <div class="countdown-overlay" id="countdownOverlay" role="timer" aria-live="assertive">
          <div class="countdown-ring" id="countdownRing">
            <span class="countdown-num" id="countdownNum">3</span>
          </div>
        </div>
        <div class="flash-overlay" id="flashOverlay" aria-hidden="true"></div>
        <div class="live-badge" id="liveBadge">
          <span class="live-dot"></span> CANLI
        </div>
      </div>

      <div class="camera-controls" id="ctrlStart">
        <button class="btn btn-primary btn-wide" id="btnStart" onclick="startCamera()">
          <span class="btn-icon">📷</span>
          <span>Kamerayı Başlat</span>
        </button>
      </div>

      <div class="camera-controls hidden" id="ctrlShoot">
        <button class="btn btn-primary btn-grow" id="btnCountdown" onclick="startCountdown()">
          <span class="btn-icon">⏱</span>
          <span>3 Saniye Sonra Çek</span>
        </button>
        <button class="btn btn-ghost" onclick="shootNow()" title="Hemen çek"><span>📸</span></button>
        <button class="btn btn-ghost" onclick="toggleCameraFacing()" title="Ön / Arka Kamera Değiştir"><span>🔄</span></button>
        <button class="btn btn-danger" onclick="stopCamera()" title="Kamerayı kapat"><span>✕</span></button>
      </div>

      <div class="photo-preview hidden" id="photoPreview">
        <div class="preview-header">
          <span class="preview-label">ÖNİZLEME</span>
          <button class="btn btn-ghost btn-sm" onclick="retake()">↺ Yeniden Çek</button>
        </div>
        <div class="preview-img-wrap">
          <img id="previewImg" src="" alt="Çekilen fotoğrafın önizlemesi" />
        </div>
      </div>

      <div class="status-msg hidden" id="statusMsg" role="alert" aria-live="polite"></div>
    </section>

    <aside class="action-col" aria-label="Yükleme paneli">

      <div class="panel-card streak-card hidden" id="streakCard">
        <div class="streak-card-inner">
          <div class="streak-info">
            <span class="streak-fire" id="streakFire">🔥</span>
            <div>
              <div class="streak-num" id="streakNum">0</div>
              <div class="streak-label">Günlük Seri</div>
            </div>
          </div>
          <div class="streak-divider"></div>
          <div class="points-info">
            <div class="points-num" id="pointsNum">0</div>
            <div class="points-label">Sadaka Puanı</div>
          </div>
        </div>
        <div class="streak-multiplier" id="streakMultiplier"></div>
      </div>

      <div class="panel-card consent-card">
        <div class="card-header">
          <div class="card-icon-wrap">📋</div>
          <h2 class="card-title">Onay &amp; Gizlilik</h2>
        </div>
        <div class="card-body">
          <label class="consent-row" for="consentStorage">
            <div class="checkbox-wrap">
              <input type="checkbox" id="consentStorage" class="consent-check" />
              <span class="checkbox-custom" aria-hidden="true">
                <svg viewBox="0 0 12 10" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <polyline points="1,5 4.5,8.5 11,1" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </div>
            <span class="consent-text">
              Fotoğrafımın <strong>projeye ait sunucularda</strong> güvenli biçimde depolanmasına izin veriyorum.
            </span>
          </label>
          <div class="consent-row info-only">
            <div class="checkbox-wrap checkbox-empty" aria-hidden="true"></div>
            <span class="consent-text">
              <p class="consent-link-row">İyilik Kılavuzu Programı hakkında detaylı bilgi için
                <a class="consent-link"
                   href="https://www.kocaeli.bel.tr/haber/iyilik-kilavuzu-kocaeline-yepyeni-bir-boyut-kazandiracak-47403.html"
                   target="_blank" rel="noopener noreferrer">tıklayınız</a>.
              </p>
            </span>
          </div>
        </div>
      </div>

      <div class="panel-card upload-card">
        <button class="btn-upload" id="btnUpload" disabled onclick="doUpload()" aria-disabled="true">
          <span class="upload-icon">☁️</span>
          <span class="upload-label">Tebessümünü Yükle</span>
          <span class="upload-arrow">→</span>
        </button>
        <div class="progress-track hidden" id="progressTrack">
          <div class="progress-fill" id="progressFill"></div>
          <span class="progress-pct" id="progressPct">0%</span>
        </div>
        <p class="upload-note" id="uploadNote">
          Fotoğraf çekip onayı işaretledikten sonra aktif olur
        </p>
      </div>

      <div class="panel-card" id="shareCard">
        <p class="share-quote">"Sen de bir <em>sadaka</em> bırak."</p>
        <p class="share-sub">Bu sayfayı arkadaşlarına ulaştır, iyiliğe ortak ol.</p>
        <div class="share-buttons">
          <button class="btn-share" id="btnShare" onclick="copyShareLink()">🔗 Linki Kopyala</button>
        </div>
      </div>

    </aside>
  </div>
</main>

<!-- ════════════════════════════════ SUCCESS MODAL ═════════════════════════════ -->
<div class="modal-backdrop hidden" id="successModal" role="dialog" aria-modal="true">
  <div class="modal-card">
    <div class="modal-icon-wrap">
      <div class="modal-icon">😊</div>
      <div class="modal-icon-ring" aria-hidden="true"></div>
    </div>
    <h2 class="modal-title">Tebessümün Yüklendi!</h2>
    <p class="modal-body">Sadakan kabul olsun. Bir tebessüm bazen birileri için en büyük hediyedir.</p>

    <div class="modal-points-earned hidden" id="modalPointsEarned">
      <span class="modal-points-icon">⭐</span>
      <span id="modalPointsEarnedNum">+1</span>
      <span class="modal-points-earned-label">sadaka puanı kazandın!</span>
    </div>

    <div class="modal-streak hidden" id="modalStreak">
      <span id="modalStreakText">🔥 2 Günlük Seri!</span>
    </div>

    <div class="modal-stats">
      <div class="modal-stat">
        <span class="modal-stat-num" id="modalTodayNum">—</span>
        <span class="modal-stat-label">Bugün</span>
      </div>
      <div class="modal-stat-div" aria-hidden="true"></div>
      <div class="modal-stat">
        <span class="modal-stat-num" id="modalTotalNum">—</span>
        <span class="modal-stat-label">Toplam</span>
      </div>
      <div class="modal-stat-div" aria-hidden="true"></div>
      <div class="modal-stat">
        <span class="modal-stat-num" id="modalPointsNum">—</span>
        <span class="modal-stat-label">Puanım</span>
      </div>
    </div>

    <button class="btn btn-primary btn-wide" onclick="resetAll()">
      <span class="btn-icon">↺</span>
      Tekrar Tebessüm Et
    </button>
  </div>
</div>

<canvas id="confettiCanvas" aria-hidden="true"></canvas>
