@{
    ViewData["Title"] = "Admin Giriş";
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>Admin — Tebessüm Sadakadır</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --petrol-dark: #0d2929; --petrol: #1a3d3d; --petrol-light: #2a5050;
      --gold: #c9a84c; --gold-light: #e0c068; --cream: #f5f0e8;
      --text: #e8dcc8; --text-muted: #9ab0a8;
    }
    body {
      background: var(--petrol-dark);
      min-height: 100vh; display: flex; align-items: center; justify-content: center;
      font-family: 'Inter', sans-serif; color: var(--text);
    }
    .login-card {
      background: linear-gradient(145deg, rgba(26,61,61,.9), rgba(13,41,41,.95));
      border: 1px solid rgba(201,168,76,.2);
      border-radius: 20px; padding: 48px 40px; width: 100%; max-width: 400px;
      box-shadow: 0 24px 64px rgba(0,0,0,.5);
    }
    .login-icon { font-size: 48px; text-align: center; margin-bottom: 8px; }
    .login-title {
      font-family: 'Cormorant Garamond', serif; font-size: 28px; font-weight: 600;
      text-align: center; color: var(--gold); margin-bottom: 4px;
    }
    .login-sub { text-align: center; font-size: 13px; color: var(--text-muted); margin-bottom: 32px; }
    .form-group { margin-bottom: 20px; }
    label { display: block; font-size: 12px; letter-spacing: 1px; text-transform: uppercase; color: var(--text-muted); margin-bottom: 8px; }
    input[type=password] {
      width: 100%; padding: 12px 16px;
      background: rgba(255,255,255,.06); border: 1px solid rgba(201,168,76,.2);
      border-radius: 10px; color: var(--text); font-size: 15px; outline: none;
      transition: border-color .2s;
    }
    input[type=password]:focus { border-color: var(--gold); }
    .btn-login {
      width: 100%; padding: 14px; background: linear-gradient(135deg, var(--gold), var(--gold-light));
      border: none; border-radius: 10px; color: var(--petrol-dark); font-size: 15px;
      font-weight: 600; cursor: pointer; transition: opacity .2s;
    }
    .btn-login:hover { opacity: .9; }
    .status { margin-top: 16px; text-align: center; font-size: 13px; min-height: 20px; color: #e88; }
    .status.ok { color: #8e8; }
  </style>
</head>
<body>
  <div class="login-card">
    <div class="login-icon">🔐</div>
    <h1 class="login-title">Admin Paneli</h1>
    <p class="login-sub">Tebessüm Sadakadır — Yönetim</p>
    <div class="form-group">
      <label for="adminPass">Şifre</label>
      <input type="password" id="adminPass" placeholder="••••••••" autofocus/>
    </div>
    <button class="btn-login" id="btnLogin">Giriş Yap</button>
    <div class="status" id="loginStatus"></div>
  </div>
  <script>
    async function doLogin() {
      const pass = document.getElementById('adminPass').value;
      const status = document.getElementById('loginStatus');
      if (!pass) { status.textContent = 'Şifre gerekli.'; return; }
      status.textContent = '';
      try {
        const res = await fetch('/user-admin/login', {
          method: 'POST',
          headers: {'Content-Type': 'application/json'},
          body: JSON.stringify({ password: pass })
        });
        if (res.ok) {
          status.textContent = 'Giriş başarılı...';
          status.className = 'status ok';
          setTimeout(() => window.location.href = '/user-admin', 500);
        } else {
          status.textContent = 'Şifre hatalı.';
          status.className = 'status';
        }
      } catch { status.textContent = 'Bağlantı hatası.'; }
    }
    document.getElementById('btnLogin').addEventListener('click', doLogin);
    document.getElementById('adminPass').addEventListener('keydown', e => { if (e.key === 'Enter') doLogin(); });
  </script>
</body>
</html>
